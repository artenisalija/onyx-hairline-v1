---
import BaseLayout from './BaseLayout.astro';
import IconArrow from '../components/IconArrow.astro';
import type { Service } from '../data/services';
import { withBase } from '../utils/paths';

interface Props { service: Service }
const { service } = Astro.props;
---

<BaseLayout title={service.title} description={`${service.tagline} Zbuloni shërbimin profesional të ${service.title.toLowerCase()} nga Onyx Hairline.`} image={service.heroImage}>
  <section class="service-hero">
    <div class="service-hero-media">
      <!-- TODO: zëvendëso fotografinë e përkohshme me imazhin përfundimtar të Onyx Hairline -->
      <img src={service.heroImage} alt={service.heroAlt} decoding="async" fetchpriority="high" />
    </div>
    <div class="service-hero-shade"></div>
    <div class="container service-hero-content">
      <a class="back-link" href={withBase('/sherbimet/')}>← Të gjitha shërbimet</a>
      <p class="eyebrow">Shërbim i personalizuar</p>
      <h1 class="display-xl">{service.title}</h1>
      <p class="hero-tagline">{service.tagline}</p>
      <a class="button" href={withBase('/kontakt/')}>Rezervo <IconArrow /></a>
    </div>
    <div class="scroll-note"><span></span> Zbuloni më shumë</div>
  </section>

  <section class="section service-overview section--ivory">
    <div class="container overview-grid">
      <div data-reveal>
        <p class="eyebrow">Qasja jonë</p>
        <h2 class="display-md">Bukuri e menduar<br /><em>deri në detaj.</em></h2>
      </div>
      <div class="overview-copy" data-reveal>
        {service.description.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </section>

  <section class="section benefits-section">
    <div class="container">
      <div class="benefits-head" data-reveal>
        <div>
          <p class="eyebrow">Pse Onyx Hairline</p>
          <h2 class="display-md">Rezultat që ndihet.</h2>
        </div>
        <p>Çdo hap ndërtohet rreth flokut tuaj, për një përvojë të qetë dhe rezultat të rafinuar.</p>
      </div>
      <div class="benefits-grid">
        {service.benefits.map((benefit, index) => (
          <article data-reveal>
            <span>0{index + 1}</span>
            <h3>{benefit.title}</h3>
            <p>{benefit.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section gallery-section section--charcoal">
    <div class="container gallery-head" data-reveal>
      <div>
        <p class="eyebrow">Frymëzim</p>
        <h2 class="display-md">Detaje që bëjnë diferencën.</h2>
      </div>
      <p>Fotografitë janë materiale të përkohshme dhe do të zëvendësohen me punimet origjinale të Onyx Hairline.</p>
    </div>
    <div class="container service-gallery">
      {service.gallery.map((image, index) => (
        <figure class:list={['image-wrap', `gallery-item-${index + 1}`]} data-reveal>
          <img src={image.src} alt={image.alt} loading="lazy" decoding="async" />
        </figure>
      ))}
    </div>
  </section>

  <section class="section faq-section section--ivory">
    <div class="container faq-grid">
      <div class="faq-title" data-reveal>
        <p class="eyebrow">Pyetje të shpeshta</p>
        <h2 class="display-md">Gjithçka që duhet të dini.</h2>
        <p class="lead">Nuk e gjetët përgjigjen? Na shkruani dhe do t’ju përgjigjemi personalisht.</p>
        <a class="text-link" href={withBase('/kontakt/')}>Na kontaktoni</a>
      </div>
      <div class="accordion" data-accordion data-reveal>
        {service.faq.map((item, index) => (
          <details open={index === 0}>
            <summary><span>{item.question}</span><i aria-hidden="true"></i></summary>
            <div><p>{item.answer}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="service-cta">
    <div class="service-cta-bg" style={`background-image: url('${service.heroImage}')`}></div>
    <div class="service-cta-shade"></div>
    <div class="container" data-reveal>
      <p class="eyebrow">Hapi i ardhshëm</p>
      <h2 class="display-lg">Gati për ndryshimin<br />tuaj?</h2>
      <a class="button" href={withBase('/kontakt/')}>Rezervo një konsultë <IconArrow /></a>
    </div>
  </section>
</BaseLayout>

<script>
  function setupAccordion() {
    document.querySelectorAll<HTMLElement>('[data-accordion]').forEach((accordion) => {
      const items = accordion.querySelectorAll<HTMLDetailsElement>('details');
      items.forEach((item) => item.addEventListener('toggle', () => {
        if (!item.open) return;
        items.forEach((other) => { if (other !== item) other.open = false; });
      }));
    });
  }
  document.addEventListener('astro:page-load', setupAccordion);
</script>

<style>
  .service-hero { position: relative; min-height: 100svh; display: flex; align-items: end; overflow: hidden; }
  .service-hero-media, .service-hero-shade { position: absolute; inset: 0; }
  .service-hero-media img { width: 100%; height: 100%; object-fit: cover; }
  .service-hero-shade { background: linear-gradient(90deg, rgba(7,7,6,.86) 0%, rgba(7,7,6,.5) 50%, rgba(7,7,6,.2)), linear-gradient(0deg, rgba(7,7,6,.8), transparent 50%); }
  .service-hero-content { position: relative; z-index: 2; padding-bottom: clamp(5rem,10vh,8rem); }
  .back-link { display: block; width: max-content; margin-bottom: clamp(4rem,10vh,8rem); color: rgba(242,234,223,.72); font-size: .68rem; letter-spacing: .12em; text-transform: uppercase; }
  .service-hero h1 { max-width: 12ch; }
  .hero-tagline { max-width: 39rem; margin: 1.5rem 0 2rem; color: rgba(242,234,223,.8); font-size: clamp(1.05rem,1.8vw,1.35rem); }
  .scroll-note { position: absolute; z-index: 2; right: 2rem; bottom: 2rem; display: flex; align-items: center; gap: .75rem; color: rgba(242,234,223,.55); font-size: .6rem; letter-spacing: .14em; text-transform: uppercase; writing-mode: vertical-rl; }
  .scroll-note span { width: 1px; height: 3rem; background: var(--copper); }
  .overview-grid { display: grid; grid-template-columns: .9fr 1fr; gap: clamp(3rem,8vw,9rem); }
  .overview-copy { padding-top: .4rem; }
  .overview-copy p { margin: 0; color: #4d4842; }
  .overview-copy p + p { margin-top: 1.3rem; }
  .benefits-head { display: flex; align-items: end; justify-content: space-between; gap: 4rem; margin-bottom: clamp(3rem,6vw,5rem); }
  .benefits-head > p { max-width: 25rem; margin: 0; color: var(--ivory-muted); }
  .benefits-grid { display: grid; grid-template-columns: repeat(4,1fr); border-top: 1px solid var(--line); }
  .benefits-grid article { min-height: 18rem; padding: 2rem 1.5rem; border-right: 1px solid var(--line); }
  .benefits-grid article:first-child { border-left: 1px solid var(--line); }
  .benefits-grid span { color: var(--copper-light); font-size: .65rem; letter-spacing: .13em; }
  .benefits-grid h3 { margin: 4.5rem 0 1rem; font-family: var(--display); font-size: 1.8rem; font-weight: 400; line-height: 1.05; }
  .benefits-grid p { margin: 0; color: var(--ivory-muted); font-size: .82rem; }
  .gallery-head { display: flex; align-items: end; justify-content: space-between; gap: 3rem; margin-bottom: 3.5rem; }
  .gallery-head > p { max-width: 26rem; margin: 0; color: var(--ivory-muted); font-size: .82rem; }
  .service-gallery { display: grid; grid-template-columns: 1.15fr .85fr; grid-template-rows: 22rem 22rem; gap: 1rem; }
  .service-gallery figure { margin: 0; }
  .service-gallery img { width: 100%; height: 100%; object-fit: cover; }
  .gallery-item-1 { grid-row: 1 / 3; }
  .faq-grid { display: grid; grid-template-columns: .8fr 1.2fr; gap: clamp(3rem,8vw,8rem); }
  .faq-title .text-link { margin-top: 2rem; }
  .accordion { border-top: 1px solid rgba(10,10,9,.2); }
  .accordion details { border-bottom: 1px solid rgba(10,10,9,.2); }
  .accordion summary { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; padding: 1.5rem 0; cursor: pointer; list-style: none; font-family: var(--display); font-size: clamp(1.35rem,2.5vw,1.75rem); line-height: 1.1; }
  .accordion summary::-webkit-details-marker { display: none; }
  .accordion summary i { position: relative; width: 1.3rem; height: 1.3rem; flex: none; }
  .accordion summary i::before, .accordion summary i::after { content: ""; position: absolute; top: 50%; left: 0; width: 100%; height: 1px; background: var(--onyx); transition: transform .25s ease; }
  .accordion summary i::after { transform: rotate(90deg); }
  .accordion details[open] summary i::after { transform: rotate(0); }
  .accordion details div { padding: 0 3rem 1.5rem 0; }
  .accordion details p { margin: 0; color: #5e5851; font-size: .9rem; }
  .service-cta { position: relative; min-height: 80vh; display: flex; align-items: center; overflow: hidden; }
  .service-cta-bg, .service-cta-shade { position: absolute; inset: 0; }
  .service-cta-bg { background-position: center; background-size: cover; transform: scale(1.04); }
  .service-cta-shade { background: linear-gradient(90deg, rgba(7,7,6,.9), rgba(7,7,6,.45)); }
  .service-cta .container { position: relative; z-index: 1; }
  .service-cta .button { margin-top: 2.25rem; }
  @media (max-width: 900px) {
    .overview-grid, .faq-grid { grid-template-columns: 1fr; }
    .benefits-grid { grid-template-columns: 1fr 1fr; }
    .benefits-grid article:nth-child(3) { border-left: 1px solid var(--line); }
    .benefits-head, .gallery-head { display: block; }
    .benefits-head > p, .gallery-head > p { margin-top: 1.5rem; }
  }
  @media (max-width: 600px) {
    .service-hero-content { padding-bottom: 4rem; }
    .back-link { margin-bottom: 4rem; }
    .scroll-note { display: none; }
    .benefits-grid { grid-template-columns: 1fr; }
    .benefits-grid article, .benefits-grid article:nth-child(3) { min-height: auto; border-right: 1px solid var(--line); border-left: 1px solid var(--line); }
    .benefits-grid h3 { margin-top: 2.5rem; }
    .service-gallery { display: block; }
    .service-gallery figure { aspect-ratio: 4/5; margin-bottom: .75rem; }
  }
</style>
