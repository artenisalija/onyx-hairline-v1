---
import type { Service } from '../data/services';
import IconArrow from './IconArrow.astro';
import { withBase } from '../utils/paths';
interface Props { service: Service; index?: number; }
const { service, index = 0 } = Astro.props;
---

<article class="service-card" data-reveal>
  <a href={withBase(`/sherbimet/${service.slug}/`)} aria-label={`Lexoni më shumë për ${service.title}`}>
    <div class="service-image image-wrap">
      <!-- TODO: zëvendëso fotografinë e përkohshme me imazhin përfundimtar të Onyx Hairline -->
      <img src={service.cardImage} alt={service.cardAlt} loading="lazy" decoding="async" />
      <span class="service-number">0{index + 1}</span>
    </div>
    <div class="service-copy">
      <div>
        <p>{service.shortLabel}</p>
        <h3>{service.title}</h3>
      </div>
      <IconArrow />
    </div>
  </a>
</article>

<style>
  .service-card a { display: block; }
  .service-image { aspect-ratio: 4 / 5; }
  .service-image img { width: 100%; height: 100%; object-fit: cover; }
  .service-number { position: absolute; z-index: 2; top: 1rem; left: 1rem; display: grid; width: 2.5rem; height: 2.5rem; place-items: center; border: 1px solid rgba(242,234,223,.4); border-radius: 50%; color: var(--ivory); font-size: .62rem; letter-spacing: .08em; }
  .service-copy { display: flex; align-items: end; justify-content: space-between; gap: 1rem; padding-top: 1.35rem; }
  .service-copy p { margin: 0 0 .35rem; color: var(--copper-light); font-size: .62rem; font-weight: 650; letter-spacing: .13em; text-transform: uppercase; }
  .service-copy h3 { margin: 0; font-family: var(--display); font-size: clamp(2rem,3vw,3rem); font-weight: 400; line-height: 1; }
  .service-copy :global(svg) { width: 1.35rem; flex: none; margin-bottom: .25rem; transition: transform .3s ease; }
  .service-card a:hover .service-copy :global(svg) { transform: translateX(.4rem); }
</style>
