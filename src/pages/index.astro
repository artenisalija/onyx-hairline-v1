---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import IconArrow from '../components/IconArrow.astro';
import { services } from '../data/services';
import { withBase } from '../utils/paths';

const gallery = [
  { src: 'https://images.unsplash.com/photo-1529139574466-a303027c1d8b?auto=format&fit=crop&fm=webp&w=1000&q=82', alt: 'Portret elegant me flokë të gjatë', className: 'gallery-a' },
  { src: 'https://images.unsplash.com/photo-1485960994840-902a67e187c8?auto=format&fit=crop&fm=webp&w=900&q=82', alt: 'Flokë me volum në dritë natyrale', className: 'gallery-b' },
  { src: 'https://images.unsplash.com/photo-1524504388940-b1c1722653e1?auto=format&fit=crop&fm=webp&w=900&q=82', alt: 'Pamje e pastër me ngjyrë natyrale flokësh', className: 'gallery-c' },
  { src: 'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?auto=format&fit=crop&fm=webp&w=1000&q=82', alt: 'Stil modern me flokë të lirë', className: 'gallery-d' },
  { src: 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&fm=webp&w=900&q=82', alt: 'Portret me flokë të dendur dhe të shëndetshëm', className: 'gallery-e' },
];
---

<BaseLayout title="Onyx Hairline — Zgjatime, Ngjyrosje dhe Trajtime Flokësh" description="Onyx Hairline sjell zgjatime me flokë njerëzorë, ngjyrosje të personalizuar dhe trajtime profesionale për flokë të bukur e të shëndetshëm.">
  <section class="home-hero">
    <div class="hero-media">
      <!-- TODO: zëvendëso fotografinë e përkohshme me materialin kryesor të Onyx Hairline -->
      <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?auto=format&fit=crop&fm=webp&w=2200&q=88" alt="Flokë të gjatë me lëvizje dhe shkëlqim natyral" fetchpriority="high" decoding="async" />
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-grain"></div>
    <div class="container hero-content">
      <p class="eyebrow">Zgjatime · Ngjyrosje · Trajtime</p>
      <h1 class="display-xl">Flokët tuaj.<br /><em>Pa kompromis.</em></h1>
      <div class="hero-bottom">
        <p>Ekspertizë, flokë njerëzorë cilësorë dhe kujdes i personalizuar për një rezultat që duket natyral dhe ndihet vetëm juaji.</p>
        <a class="button" href={withBase('/kontakt/')}>Rezervo një konsultë <IconArrow /></a>
      </div>
    </div>
    <div class="hero-index" aria-hidden="true"><span>01</span><i></i><span>05</span></div>
  </section>

  <section class="intro section--ivory">
    <div class="container intro-grid">
      <p class="intro-side" data-reveal>Onyx Hairline · Tiranë</p>
      <div data-reveal>
        <p class="eyebrow">Më shumë se një ndryshim</p>
        <h2 class="display-lg">Bukuri që lë<br /><em>gjurmë.</em></h2>
      </div>
      <p class="intro-copy" data-reveal>Besojmë se floku i bukur nis me dëgjimin. Çdo shërbim formësohet rreth tipareve, strukturës dhe stilit tuaj — me teknikë të saktë dhe një sy të stërvitur për detajin.</p>
    </div>
  </section>

  <section class="services section">
    <div class="container section-heading" data-reveal>
      <div>
        <p class="eyebrow">Shërbimet tona</p>
        <h2 class="display-md">Art, teknikë dhe kujdes.</h2>
      </div>
      <a class="text-link" href={withBase('/sherbimet/')}>Shikoni të gjitha</a>
    </div>
    <div class="container service-grid">
      {services.map((service, index) => <ServiceCard service={service} index={index} />)}
    </div>
  </section>

  <section class="statement section">
    <div class="statement-photo image-wrap" data-reveal>
      <img src="https://images.unsplash.com/photo-1562322140-8baeececf3df?auto=format&fit=crop&fm=webp&w=1400&q=84" alt="Flokë profesionalisht të stiluar me shkëlqim" loading="lazy" decoding="async" />
      <span>Material i përkohshëm</span>
    </div>
    <div class="statement-copy" data-reveal>
      <p class="eyebrow">Cilësi që shihet dhe ndihet</p>
      <h2 class="display-md">Flokë njerëzorë.<br />Rezultat <em>i vërtetë.</em></h2>
      <p>Zgjedhim flokë njerëzorë për lëvizjen, butësinë dhe mundësinë e stilimit të tyre. Çdo tufë përshtatet me nuancën dhe strukturën tuaj, që bashkimi të mbetet i rafinuar dhe i natyrshëm.</p>
      <a class="button button--ghost" href={withBase('/sherbimet/zgjatime-flokesh/')}>Zbuloni zgjatimet <IconArrow /></a>
      <div class="statement-facts">
        <div><strong>01</strong><span>Përzgjedhje<br />e kujdesshme</span></div>
        <div><strong>02</strong><span>Aplikim<br />i personalizuar</span></div>
        <div><strong>03</strong><span>Mirëmbajtje<br />e udhëzuar</span></div>
      </div>
    </div>
  </section>

  <section class="gallery section--charcoal section">
    <div class="container gallery-title" data-reveal>
      <div>
        <p class="eyebrow">Pamje & frymëzim</p>
        <h2 class="display-md">Bota e Onyx.</h2>
      </div>
      <p>Galeria përmban fotografi të përkohshme që do të zëvendësohen me punimet origjinale të Onyx Hairline.</p>
    </div>
    <div class="container masonry-gallery">
      {gallery.map((item) => (
        <figure class:list={['image-wrap', item.className]} data-reveal>
          <img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
        </figure>
      ))}
    </div>
  </section>

  <section class="testimonials section section--ivory">
    <div class="container testimonial-head" data-reveal>
      <p class="eyebrow">Fjalët e klienteve</p>
      <span>Dëshmi shembull · për zëvendësim</span>
    </div>
    <div class="container testimonial-grid">
      <blockquote data-reveal>
        <span>“</span>
        <p>Rezultati duket kaq natyral sa askush nuk e kupton që kam zgjatime. Nga konsultimi te kujdesi pas shërbimit, gjithçka ishte e menduar me detaj.</p>
        <footer>— Elira K. <small>Dëshmi shembull</small></footer>
      </blockquote>
      <blockquote data-reveal>
        <span>“</span>
        <p>Më në fund gjeta nuancën që më ndriçon fytyrën dhe rritet bukur. Flokët e mi ndihen të butë, plot dritë dhe shumë më të shëndetshëm.</p>
        <footer>— Anisa M. <small>Dëshmi shembull</small></footer>
      </blockquote>
    </div>
  </section>

  <section class="closing-cta">
    <div class="closing-photo"></div>
    <div class="closing-overlay"></div>
    <div class="container" data-reveal>
      <p class="eyebrow">Fillon me një bisedë</p>
      <h2 class="display-lg">Le të krijojmë<br /><em>pamjen tuaj.</em></h2>
      <p>Na tregoni çfarë dëshironi. Ne do t’ju udhëzojmë drejt shërbimit dhe rezultatit të duhur për ju.</p>
      <a class="button" href={withBase('/kontakt/')}>Rezervo një konsultë <IconArrow /></a>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero { position: relative; min-height: 100svh; display: flex; align-items: end; overflow: hidden; }
  .hero-media, .hero-overlay, .hero-grain { position: absolute; inset: 0; }
  .hero-media img { width: 100%; height: 100%; object-fit: cover; object-position: center 35%; }
  .hero-overlay { background: linear-gradient(90deg, rgba(6,6,5,.82) 0%, rgba(6,6,5,.35) 60%, rgba(6,6,5,.18)), linear-gradient(0deg, rgba(6,6,5,.8), transparent 58%); }
  .hero-grain { opacity: .08; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.4'/%3E%3C/svg%3E"); }
  .hero-content { position: relative; z-index: 2; padding-bottom: clamp(4rem,9vh,7rem); }
  .hero-content h1 { max-width: 11ch; }
  .hero-bottom { display: flex; max-width: 57rem; align-items: end; justify-content: space-between; gap: 3rem; margin-top: 2rem; }
  .hero-bottom p { max-width: 35rem; margin: 0; color: rgba(242,234,223,.75); }
  .hero-index { position: absolute; z-index: 2; right: 2rem; bottom: 2.2rem; display: flex; align-items: center; gap: .6rem; color: rgba(242,234,223,.55); font-size: .6rem; letter-spacing: .1em; }
  .hero-index i { width: 4rem; height: 1px; background: rgba(242,234,223,.25); }
  .intro { padding-block: clamp(6rem,12vw,11rem); }
  .intro-grid { display: grid; grid-template-columns: .35fr 1.2fr .65fr; align-items: start; gap: clamp(2rem,5vw,6rem); }
  .intro-side { margin: .8rem 0 0; color: #8b8177; font-size: .62rem; letter-spacing: .14em; text-transform: uppercase; writing-mode: vertical-rl; }
  .intro-copy { align-self: end; margin: 0 0 .5rem; color: #554f49; }
  .section-heading { display: flex; align-items: end; justify-content: space-between; gap: 2rem; margin-bottom: 3.5rem; }
  .service-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; }
  .service-grid :global(.service-card:nth-child(2)) { margin-top: 4rem; }
  .statement { display: grid; grid-template-columns: 1fr 1fr; padding: 0; min-height: 52rem; background: #11100f; }
  .statement-photo { min-height: 44rem; }
  .statement-photo img { width: 100%; height: 100%; object-fit: cover; }
  .statement-photo span { position: absolute; z-index: 2; bottom: 1rem; left: 1rem; color: rgba(242,234,223,.65); font-size: .58rem; letter-spacing: .12em; text-transform: uppercase; }
  .statement-copy { display: flex; flex-direction: column; justify-content: center; padding: clamp(3rem,7vw,8rem); }
  .statement-copy > p:not(.eyebrow) { max-width: 35rem; margin: 2rem 0; color: var(--ivory-muted); }
  .statement-copy .button { width: max-content; }
  .statement-facts { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; margin-top: clamp(4rem,7vw,7rem); padding-top: 1.5rem; border-top: 1px solid var(--line); }
  .statement-facts div { display: flex; gap: .75rem; }
  .statement-facts strong { color: var(--copper-light); font-size: .6rem; letter-spacing: .12em; }
  .statement-facts span { color: #aaa39b; font-size: .66rem; line-height: 1.5; text-transform: uppercase; }
  .gallery-title { display: flex; align-items: end; justify-content: space-between; gap: 2rem; margin-bottom: 3rem; }
  .gallery-title > p { max-width: 27rem; margin: 0; color: var(--ivory-muted); font-size: .8rem; }
  .masonry-gallery { display: grid; grid-template-columns: 1fr .7fr 1fr; grid-template-rows: 18rem 20rem 18rem; gap: .75rem; }
  .masonry-gallery figure { margin: 0; }
  .masonry-gallery img { width: 100%; height: 100%; object-fit: cover; }
  .gallery-a { grid-row: 1 / 3; }
  .gallery-b { grid-row: 1 / 2; }
  .gallery-c { grid-row: 1 / 3; }
  .gallery-d { grid-column: 1 / 3; grid-row: 3 / 4; }
  .gallery-e { grid-column: 3; grid-row: 3; }
  .testimonial-head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding-bottom: 2rem; border-bottom: 1px solid rgba(10,10,9,.18); }
  .testimonial-head .eyebrow { margin: 0; }
  .testimonial-head > span { color: #857c73; font-size: .62rem; letter-spacing: .1em; text-transform: uppercase; }
  .testimonial-grid { display: grid; grid-template-columns: 1fr 1fr; }
  blockquote { position: relative; margin: 0; padding: clamp(3rem,6vw,6rem); }
  blockquote + blockquote { border-left: 1px solid rgba(10,10,9,.18); }
  blockquote > span { display: block; height: 3rem; color: var(--copper); font-family: var(--display); font-size: 5rem; line-height: 1; }
  blockquote > p { margin: 1rem 0 2.5rem; font-family: var(--display); font-size: clamp(1.7rem,3vw,2.5rem); line-height: 1.2; }
  blockquote footer { font-size: .68rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; }
  blockquote small { display: block; margin-top: .35rem; color: #8c8379; font-weight: 500; }
  .closing-cta { position: relative; min-height: 85vh; display: flex; align-items: center; overflow: hidden; }
  .closing-photo, .closing-overlay { position: absolute; inset: 0; }
  .closing-photo { background: url('https://images.unsplash.com/photo-1487412720507-e7ab37603c6f?auto=format&fit=crop&fm=webp&w=2000&q=84') center 35% / cover; }
  .closing-overlay { background: linear-gradient(90deg, rgba(6,6,5,.88), rgba(6,6,5,.25)); }
  .closing-cta .container { position: relative; z-index: 1; }
  .closing-cta p:not(.eyebrow) { max-width: 35rem; margin: 2rem 0; color: var(--ivory-muted); }
  @media (max-width: 900px) {
    .intro-grid { grid-template-columns: 1fr 1fr; }
    .intro-side { display: none; }
    .service-grid { grid-template-columns: 1fr 1fr; }
    .service-grid :global(.service-card:nth-child(2)) { margin-top: 3rem; }
    .statement { grid-template-columns: 1fr; }
    .statement-photo { min-height: 70vh; }
    .gallery-title { display: block; }
    .gallery-title > p { margin-top: 1.5rem; }
  }
  @media (max-width: 650px) {
    .hero-bottom { display: block; }
    .hero-bottom .button { margin-top: 1.75rem; }
    .hero-index { display: none; }
    .intro-grid { grid-template-columns: 1fr; }
    .service-grid { grid-template-columns: 1fr; gap: 3rem; }
    .service-grid :global(.service-card:nth-child(2)) { margin-top: 0; }
    .statement-copy { padding: 5rem 1.25rem; }
    .statement-facts { grid-template-columns: 1fr; }
    .masonry-gallery { grid-template-columns: 1fr 1fr; grid-template-rows: 22rem 15rem 22rem; }
    .gallery-a { grid-column: 1; grid-row: 1; }
    .gallery-b { grid-column: 2; grid-row: 1; }
    .gallery-c { grid-column: 1 / 3; grid-row: 2; }
    .gallery-d { grid-column: 1; grid-row: 3; }
    .gallery-e { grid-column: 2; grid-row: 3; }
    .testimonial-grid { grid-template-columns: 1fr; }
    blockquote { padding-inline: 0; }
    blockquote + blockquote { border-top: 1px solid rgba(10,10,9,.18); border-left: 0; }
  }
</style>
